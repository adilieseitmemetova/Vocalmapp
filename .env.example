NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for the YouTube Data API v3 search route.
# Do not expose this value with a NEXT_PUBLIC_ prefix.
YOUTUBE_API_KEY=

# Optional. Server-only Resend key for future direct email integrations.
# Supabase Auth SMTP uses this key in the Supabase dashboard, not in browser code.
RESEND_API_KEY=

# Optional. Keep server-only and never expose with NEXT_PUBLIC_.
# The current app does not require this key.
SUPABASE_SERVICE_ROLE_KEY=
